generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [postgis, btree_gist]
}

// =====================================================================
// Enums
// =====================================================================

enum SkillLevel {
  INICIANTE
  INTERMEDIARIO
  AVANCADO
  COMPETITIVO
}

/// Como a quadra existe no ecossistema da cidade
enum CourtType {
  PUBLIC_OFFICIAL // pública, com sistema oficial de agendamento
  PUBLIC_UNOFFICIAL // pública, sem sistema de agendamento
  PRIVATE // clube/quadra privada
}

/// Como a reserva dessa quadra é tratada pela plataforma
enum BookingMode {
  OFFICIAL_INTEGRATION // agenda oficial (fonte da verdade é externa)
  INTERNAL // agenda controlada por nós (quadra privada cadastrada pelo dono)
  INFORMATIONAL // sem agenda; só orientamos como reservar
}

enum SurfaceType {
  SAIBRO
  QUADRA_DURA
  GRAMA_SINTETICA
  CARPETE
  CONCRETO
  OUTRO
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum MatchStatus {
  OPEN
  FULL
  CANCELLED
  COMPLETED
}

enum MatchVisibility {
  PUBLIC
  FRIENDS_ONLY
  PRIVATE
}

enum ParticipantStatus {
  INVITED
  CONFIRMED
  WAITLIST
  DECLINED
  LEFT
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
  DECLINED
  BLOCKED
}

enum NotificationType {
  MATCH_INVITE
  MATCH_JOIN_REQUEST
  MATCH_UPDATE
  MATCH_CANCELLED
  FRIEND_REQUEST
  FRIEND_ACCEPTED
  BOOKING_CONFIRMED
  BOOKING_CANCELLED
  NEW_REVIEW
  NEW_MESSAGE
}

// =====================================================================
// Identidade / Auth (compatível com o adapter Prisma do NextAuth — Etapa 3)
// =====================================================================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String? // null quando o usuário só usa login social

  phone        String?
  bio          String?
  skillLevel   SkillLevel @default(INICIANTE)
  neighborhood String?
  city         String     @default("Recife")
  state        String     @default("PE")
  latitude     Float?
  longitude    Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts       Account[]
  sessions       Session[]
  favoriteCourts FavoriteCourt[]
  courtReviews   CourtReview[]
  ownedCourts    Court[]         @relation("CourtOwner")
  bookings       Booking[]

  organizedMatches    Match[]            @relation("MatchOrganizer")
  matchParticipations MatchParticipant[]
  matchMessages       MatchMessage[]

  friendshipsSent     Friendship[] @relation("FriendshipRequester")
  friendshipsReceived Friendship[] @relation("FriendshipAddressee")

  notifications Notification[]

  ratingsGiven    PlayerRating[] @relation("RatingRater")
  ratingsReceived PlayerRating[] @relation("RatingRated")

  @@index([city, neighborhood])
}

/// Contas de provedores OAuth vinculadas a um usuário (Google, Apple...)
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// =====================================================================
// Quadras
// =====================================================================

model Court {
  id          String  @id @default(cuid())
  name        String
  description String?

  courtType   CourtType
  bookingMode BookingMode
  surfaceType SurfaceType
  isLighted   Boolean     @default(false)
  isIndoor    Boolean     @default(false)

  address      String
  neighborhood String
  city         String                                 @default("Recife")
  state        String                                 @default("PE")
  latitude     Float
  longitude    Float
  /// Coluna geoespacial (PostGIS), mantida em sincronia com latitude/longitude
  /// via trigger de banco. Usada em consultas de proximidade (ST_DWithin) na
  /// camada de infraestrutura (raw SQL), não pelo Prisma Client diretamente.
  location     Unsupported("geography(Point, 4326)")?

  hourlyPriceCents    Int?
  currency            String  @default("BRL")
  officialBookingUrl  String?
  bookingInstructions String?
  phone               String?

  ownerId String?
  owner   User?   @relation("CourtOwner", fields: [ownerId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  photos       CourtPhoto[]
  openingHours CourtOpeningHour[]
  reviews      CourtReview[]
  favoritedBy  FavoriteCourt[]
  bookings     Booking[]
  matches      Match[]

  @@index([neighborhood])
  @@index([courtType])
  @@index([surfaceType])
}

model CourtPhoto {
  id       String @id @default(cuid())
  courtId  String
  court    Court  @relation(fields: [courtId], references: [id], onDelete: Cascade)
  url      String
  position Int    @default(0)

  createdAt DateTime @default(now())

  @@index([courtId])
}

/// Horário de funcionamento por dia da semana (0 = domingo ... 6 = sábado)
model CourtOpeningHour {
  id        String @id @default(cuid())
  courtId   String
  court     Court  @relation(fields: [courtId], references: [id], onDelete: Cascade)
  dayOfWeek Int
  opensAt   String // "08:00"
  closesAt  String // "22:00"

  @@unique([courtId, dayOfWeek])
}

model CourtReview {
  id      String  @id @default(cuid())
  courtId String
  court   Court   @relation(fields: [courtId], references: [id], onDelete: Cascade)
  userId  String
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  rating  Int // 1 a 5 (checado no banco)
  comment String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([courtId, userId])
  @@index([courtId])
}

model FavoriteCourt {
  userId  String
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  courtId String
  court   Court  @relation(fields: [courtId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@id([userId, courtId])
}

// =====================================================================
// Reservas
// =====================================================================

model Booking {
  id      String @id @default(cuid())
  courtId String
  court   Court  @relation(fields: [courtId], references: [id], onDelete: Cascade)
  userId  String
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  startTime         DateTime
  endTime           DateTime
  status            BookingStatus @default(PENDING)
  externalReference String? // id da reserva no sistema oficial, quando existir
  notes             String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([courtId, startTime])
  @@index([userId])
}

// =====================================================================
// Partidas / Peladas
// =====================================================================

model Match {
  id          String  @id @default(cuid())
  organizerId String
  organizer   User    @relation("MatchOrganizer", fields: [organizerId], references: [id])
  courtId     String?
  court       Court?  @relation(fields: [courtId], references: [id])

  title           String
  description     String?
  scheduledAt     DateTime
  durationMinutes Int             @default(60)
  minSkillLevel   SkillLevel?
  maxSkillLevel   SkillLevel?
  maxPlayers      Int             @default(4)
  status          MatchStatus     @default(OPEN)
  visibility      MatchVisibility @default(PUBLIC)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  participants MatchParticipant[]
  messages     MatchMessage[]
  ratings      PlayerRating[]

  @@index([scheduledAt])
  @@index([status])
}

model MatchParticipant {
  id      String @id @default(cuid())
  matchId String
  match   Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)
  userId  String
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  status   ParticipantStatus @default(INVITED)
  joinedAt DateTime          @default(now())

  @@unique([matchId, userId])
}

model MatchMessage {
  id      String @id @default(cuid())
  matchId String
  match   Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)
  userId  String
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  content String

  createdAt DateTime @default(now())

  @@index([matchId, createdAt])
}

// =====================================================================
// Social
// =====================================================================

model Friendship {
  id          String           @id @default(cuid())
  requesterId String
  requester   User             @relation("FriendshipRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  addresseeId String
  addressee   User             @relation("FriendshipAddressee", fields: [addresseeId], references: [id], onDelete: Cascade)
  status      FriendshipStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([requesterId, addresseeId])
}

model PlayerRating {
  id          String @id @default(cuid())
  matchId     String
  match       Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)
  raterId     String
  rater       User   @relation("RatingRater", fields: [raterId], references: [id], onDelete: Cascade)
  ratedUserId String
  ratedUser   User   @relation("RatingRated", fields: [ratedUserId], references: [id], onDelete: Cascade)

  rating  Int // 1 a 5 (checado no banco)
  comment String?

  createdAt DateTime @default(now())

  @@unique([matchId, raterId, ratedUserId])
}

model Notification {
  id      String           @id @default(cuid())
  userId  String
  user    User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type    NotificationType
  payload Json?
  readAt  DateTime?

  createdAt DateTime @default(now())

  @@index([userId, readAt])
}
